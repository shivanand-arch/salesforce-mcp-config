<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>AI Sales Assistant User</label>
    <description>Grants access to the Ask Salesforce AI assistant LWC component and Apex controllers</description>
    <hasActivationRequired>false</hasActivationRequired>
    <classAccesses>
        <apexClass>AiSalesAssistantController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>GeminiApiService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>ClaudeApiService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>SoqlSanitizer</apexClass>
        <enabled>true</enabled>
    </classAccesses>
</PermissionSet>
